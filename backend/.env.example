# GitHub Copilot Usage Metrics Dashboard - Backend
# Copy this file to .env and fill in your values

# GitHub Personal Access Token (classic) with manage_billing:copilot or read:enterprise scope
GITHUB_TOKEN=

# GitHub API base URL
GITHUB_API_URL=https://api.github.com

# API version header
GITHUB_API_VERSION=2026-03-10

# Set to true to use mock data instead of real GitHub API
MOCK_MODE=true

# Your enterprise slug
ENTERPRISE_SLUG=my-enterprise

# Comma-separated list of organizations to track
ORGANIZATIONS=org-alpha,org-beta,org-gamma
